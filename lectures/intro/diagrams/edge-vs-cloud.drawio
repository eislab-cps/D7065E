<mxfile host="app.diagrams.net">
  <diagram id="edge-vs-cloud" name="edge-vs-cloud">
    <mxGraphModel dx="1000" dy="600" grid="0" page="1" pageScale="1" pageWidth="1140" pageHeight="460" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="bld" value="THE BUILDING" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#89A5BE;strokeWidth=2;verticalAlign=top;fontColor=#89A5BE;fontSize=16;fontStyle=1;fontFamily=Helvetica;spacingTop=10;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="50" width="480" height="300" as="geometry"/>
        </mxCell>
        <mxCell id="sens" value="sensors&#10;temp · CO₂ · smoke" style="ellipse;whiteSpace=wrap;html=1;fillColor=#0B3B66;strokeColor=#89A5BE;strokeWidth=2;fontColor=#FFFFFF;fontSize=14;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="75" y="130" width="150" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="edge" value="EDGE NODE&#10;compute next to the sensors" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF8247;strokeColor=none;fontColor=#032040;fontSize=15;fontStyle=1;fontFamily=Helvetica;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="300" y="130" width="190" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="e1" value="~1 ms" style="endArrow=block;startArrow=block;html=1;strokeColor=#7FE3A1;strokeWidth=3;fontColor=#7FE3A1;fontSize=16;fontStyle=1;fontFamily=Helvetica;labelBackgroundColor=none;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="sens" target="edge">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="off" value="keeps working when the internet does not&#10;data never has to leave the building (privacy)" style="text;html=1;align=center;fontColor=#7FE3A1;fontSize=14;fontStyle=2;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="90" y="250" width="390" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="cloud" value="THE CLOUD&#10;&#10;near-infinite compute and storage&#10;ideal for training and heavy analytics" style="shape=cloud;whiteSpace=wrap;html=1;fillColor=#0B3B66;strokeColor=#89A5BE;strokeWidth=2;fontColor=#FFFFFF;fontSize=15;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="800" y="60" width="310" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="e2" value="50–300 ms · hundreds of km" style="endArrow=block;startArrow=block;html=1;strokeColor=#E05252;strokeWidth=3;fontColor=#E05252;fontSize=16;fontStyle=1;fontFamily=Helvetica;labelBackgroundColor=none;dashed=1;exitX=1;exitY=0.5;entryX=0;entryY=0.55;" edge="1" parent="1" source="edge" target="cloud">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="dep" value="depends on connectivity — and on someone else&#39;s datacenter" style="text;html=1;align=center;fontColor=#E05252;fontSize=14;fontStyle=2;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="700" y="290" width="420" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="cap" value="A real-time control loop belongs at the edge. Training, fleet analytics, and history belong in the cloud. Good architectures use both." style="text;html=1;align=center;fontColor=#FFFFFF;fontSize=16;fontStyle=2;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="100" y="395" width="940" height="30" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
