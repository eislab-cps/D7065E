        <mxCell id="oral" value="ORAL EXAM&#10;(individual)&#10;&#10;a gate, not a modifier:&#10;confirms your level,&#10;never raises it&#10;&#10;teammates may end up&#10;with different grades&#10;&#10;cannot defend it → U" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0B3B66;strokeColor=#FF8247;strokeWidth=2;fontColor=#FFFFFF;fontSize=14;fontFamily=Helvetica;verticalAlign=top;spacingTop=12;spacing=8;arcSize=6;" vertex="1" parent="1">
