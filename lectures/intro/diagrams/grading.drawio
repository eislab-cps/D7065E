        <mxCell id="s1" value="STAGE 1 — THE GATE&#10;&#10;all mandatory requirements present?&#10;&#10;separate processes · closed loop&#10;autonomous component · data pipeline&#10;architecture doc · executed test plan&#10;dashboard · report" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#89A5BE;strokeWidth=2;dashed=1;fontColor=#FFFFFF;fontSize=14;fontFamily=Helvetica;verticalAlign=top;spacingTop=12;spacing=8;arcSize=6;" vertex="1" parent="1">
