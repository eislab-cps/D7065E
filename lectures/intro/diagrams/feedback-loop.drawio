<mxfile host="app.diagrams.net">
  <diagram id="feedback-loop" name="feedback-loop">
    <mxGraphModel dx="1000" dy="600" grid="0" page="1" pageScale="1" pageWidth="1140" pageHeight="470" math="0" shadow="0" background="#032040">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="sim" value="SIMULATOR&#10;the physics model" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0B3B66;strokeColor=#89A5BE;strokeWidth=2;fontColor=#FFFFFF;fontSize=15;fontFamily=Helvetica;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="60" width="220" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="read" value="SENSOR READINGS&#10;temperature rises, smoke spreads" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0B3B66;strokeColor=#89A5BE;strokeWidth=2;fontColor=#FFFFFF;fontSize=15;fontFamily=Helvetica;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="430" y="60" width="280" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="agent" value="AGENT&#10;reads, reasons, decides" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0B3B66;strokeColor=#89A5BE;strokeWidth=2;fontColor=#FFFFFF;fontSize=15;fontFamily=Helvetica;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="840" y="60" width="220" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="cmd" value="ACTUATOR COMMANDS&#10;sprinkler on · heat off · vent up" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0B3B66;strokeColor=#89A5BE;strokeWidth=2;fontColor=#FFFFFF;fontSize=15;fontFamily=Helvetica;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="430" y="220" width="280" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="a1" style="endArrow=block;html=1;strokeColor=#FF8247;strokeWidth=3;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="sim" target="read"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a2" style="endArrow=block;html=1;strokeColor=#FF8247;strokeWidth=3;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="read" target="agent"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a3" style="endArrow=block;html=1;strokeColor=#FF8247;strokeWidth=3;exitX=0.5;exitY=1;entryX=1;entryY=0.5;" edge="1" parent="1" source="agent" target="cmd">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="950" y="255"/></Array></mxGeometry>
        </mxCell>
        <mxCell id="a4" value="the commands feed back into the physics" style="endArrow=block;html=1;strokeColor=#FF8247;strokeWidth=3;fontColor=#FF8247;fontSize=14;fontStyle=2;fontFamily=Helvetica;labelBackgroundColor=none;exitX=0;exitY=0.5;entryX=0.5;entryY=1;" edge="1" parent="1" source="cmd" target="sim">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="190" y="255"/></Array><mxPoint x="0" y="18" as="offset"/></mxGeometry>
        </mxCell>
        <mxCell id="warn" value="THE MOST COMMON MISTAKE: actuator commands that change nothing.&#10;If sprinkler-on does not reduce smoke in the next readings, your loop is OPEN —&#10;the agent is just decorating a log file. Closing this loop is the heart of the project." style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#E05252;strokeWidth=2;dashed=1;fontColor=#E05252;fontSize=15;fontStyle=1;fontFamily=Helvetica;spacing=10;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="170" y="330" width="800" height="100" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
