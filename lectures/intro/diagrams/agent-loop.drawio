        <mxCell id="tools" value="TOOLS&#10;&#10;REST APIs · database queries&#10;actuator commands · an LLM if useful" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#89A5BE;strokeWidth=2;dashed=1;fontColor=#89A5BE;fontSize=13;fontStyle=1;fontFamily=Helvetica;verticalAlign=top;spacingTop=8;spacing=6;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="280" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="cap" value="rules → ML → agents: however it decides, the loop is the same — and your project must close it" style="text;html=1;align=center;fontColor=#FFFFFF;fontSize=16;fontStyle=2;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="300" y="455" width="700" height="26" as="geometry"/>
