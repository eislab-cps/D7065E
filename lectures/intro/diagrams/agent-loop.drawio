<mxfile host="app.diagrams.net">
  <diagram id="agent-loop" name="agent-loop">
    <mxGraphModel dx="1000" dy="600" grid="0" page="1" pageScale="1" pageWidth="1140" pageHeight="480" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="agent" value="AI AGENT" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FF8247;strokeColor=none;fontColor=#032040;fontSize=18;fontStyle=1;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="430" y="190" width="170" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="p1" value="PERCEIVE&#10;read sensors, query the pipeline" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0B3B66;strokeColor=#89A5BE;strokeWidth=2;fontColor=#FFFFFF;fontSize=14;fontFamily=Helvetica;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="420" y="40" width="190" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="p2" value="REASON&#10;what is happening? what matters?" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0B3B66;strokeColor=#89A5BE;strokeWidth=2;fontColor=#FFFFFF;fontSize=14;fontFamily=Helvetica;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="730" y="130" width="200 " height="60" as="geometry"/>
        </mxCell>
        <mxCell id="p3" value="PLAN&#10;choose an action toward the goal" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0B3B66;strokeColor=#89A5BE;strokeWidth=2;fontColor=#FFFFFF;fontSize=14;fontFamily=Helvetica;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="730" y="290" width="200" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="p4" value="ACT&#10;command actuators (via tools)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0B3B66;strokeColor=#89A5BE;strokeWidth=2;fontColor=#FFFFFF;fontSize=14;fontFamily=Helvetica;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="420" y="380" width="190" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="p5" value="OBSERVE&#10;did the world change as expected?" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0B3B66;strokeColor=#89A5BE;strokeWidth=2;fontColor=#FFFFFF;fontSize=14;fontFamily=Helvetica;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="110" y="210" width="200" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="l1" style="curved=1;endArrow=block;html=1;strokeColor=#FF8247;strokeWidth=3;exitX=1;exitY=0.5;entryX=0.5;entryY=0;" edge="1" parent="1" source="p1" target="p2"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="780" y="70"/></Array></mxGeometry></mxCell>
        <mxCell id="l2" style="curved=1;endArrow=block;html=1;strokeColor=#FF8247;strokeWidth=3;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="p2" target="p3"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="880" y="240"/></Array></mxGeometry></mxCell>
        <mxCell id="l3" style="curved=1;endArrow=block;html=1;strokeColor=#FF8247;strokeWidth=3;exitX=0.5;exitY=1;entryX=1;entryY=0.5;" edge="1" parent="1" source="p3" target="p4"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="780" y="415"/></Array></mxGeometry></mxCell>
        <mxCell id="l4" style="curved=1;endArrow=block;html=1;strokeColor=#FF8247;strokeWidth=3;exitX=0;exitY=0.5;entryX=0.5;entryY=1;" edge="1" parent="1" source="p4" target="p5"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="200" y="400"/></Array></mxGeometry></mxCell>
        <mxCell id="l5" style="curved=1;endArrow=block;html=1;strokeColor=#FF8247;strokeWidth=3;exitX=0.5;exitY=0;entryX=0;entryY=0.5;" edge="1" parent="1" source="p5" target="p1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="220" y="70"/></Array></mxGeometry></mxCell>
        <mxCell id="guard" value="GUARDRAILS&#10;&#10;action limits · validation&#10;human-in-the-loop for the dangerous stuff&#10;(never let an LLM open the fire doors unchecked)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#E05252;strokeWidth=2;dashed=1;fontColor=#E05252;fontSize=13;fontStyle=1;fontFamily=Helvetica;verticalAlign=top;spacingTop=8;spacing=6;arcSize=8;" vertex="1" parent="1">
