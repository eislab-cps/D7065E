direction: right
laptop: Student laptop {
  buildsim: BuildSim :9090 {
    shape: cylinder
  }
  compose: docker compose {
    sim: simulator
    sensor: sensor svc
    actuator: actuator svc
    agent: agent
    broker: broker {
      shape: queue
    }
    store: store {
      shape: cylinder
    }
    dash: dashboard
  }
}
gpu: GPU server\n(LLM, optional) {
  style.stroke-dash: 4
  style.fill: transparent
}
laptop.compose.agent -> gpu: inference
