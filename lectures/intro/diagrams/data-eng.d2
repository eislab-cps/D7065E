direction: right
sensors: Sensors
ingest: Ingest\n(stream / batch)
bronze: Bronze\nraw {
  shape: cylinder
}
silver: Silver\ncleaned {
  shape: cylinder
}
gold: Gold\nfeatures {
  shape: cylinder
}
ml: ML / decision
tsdb: Time-series DB\n(live) {
  shape: cylinder
}

sensors -> ingest: volume, velocity, variety
ingest -> bronze
bronze -> silver: clean
silver -> gold: features
gold -> ml
ingest -> tsdb: recent queries
